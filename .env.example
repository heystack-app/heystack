# Copy to .env and adjust as needed. Every value has a working local default.

# --- Database ---
POSTGRES_USER=heystack
POSTGRES_PASSWORD=heystack
POSTGRES_DB=heystack
POSTGRES_PORT=5432
# Used by the app and the ingest CLI. For local dev (db in Docker, app on host)
# the host is localhost. Inside docker-compose the app uses the service name.
DATABASE_URL=postgres://heystack:heystack@localhost:5432/heystack

# --- Models (local, via Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
# bge-m3 is multilingual (100+ languages), 1024-dim. EMBEDDING_DIM must match the
# model AND the vector(...) column in db/init.sql. For an English-only lighter
# setup: EMBEDDING_MODEL=nomic-embed-text with EMBEDDING_DIM=768 (and edit init.sql).
# Changing the model or dimension requires re-ingesting your documents.
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024
CHAT_MODEL=llama3.1:8b
# Reranker. Defaults to CHAT_MODEL. Set ENABLE_RERANK=false to skip it (faster).
# RERANK_MODEL=llama3.1:8b
ENABLE_RERANK=true

# --- App ---
APP_PORT=3000
# Set to true ONLY for a public/shared instance: hides "Scan my computer" and
# disables the scan API (so it cannot read the server's filesystem).
NEXT_PUBLIC_DEMO_MODE=false

# --- Optional cloud fallback (leave blank to stay fully local and private) ---
# OPENAI_API_KEY=
